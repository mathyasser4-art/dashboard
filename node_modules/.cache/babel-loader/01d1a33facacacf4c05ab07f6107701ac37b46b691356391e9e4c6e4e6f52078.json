{"ast":null,"code":"const URL='https://abacus-2ntk.onrender.com/system/getAllSystem';const getSystem=(setAllSystem,setLoading)=>{setLoading(true);fetch(URL,{method:'get',headers:{'Content-Type':'application/json'}}).then(response=>response.json()).then(responseJson=>{if(responseJson.message==='success'){setAllSystem(responseJson.allSystem);setLoading(false);}else{setLoading(false);}}).catch(error=>{console.log(error.message);setLoading(false);});};export default getSystem;","map":null,"metadata":{},"sourceType":"module","externalDependencies":[]}