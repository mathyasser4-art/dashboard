{"ast":null,"code":"const URL='https://practice-papers.onrender.com/school/disableSchool';const Token=localStorage.getItem('O_authDB');const disableSchool=(schoolID,setAllSchools)=>{fetch(\"\".concat(URL,\"/\").concat(schoolID),{method:'put',headers:{'Content-Type':'application/json','authrization':\"pracYas09\".concat(Token)}}).then(response=>response.json()).then(responseJson=>{if(responseJson.message==='success'){setAllSchools(responseJson.allSchools);}else{console.log(responseJson.message);}}).catch(error=>{console.log(error.message);});};export default disableSchool;","map":null,"metadata":{},"sourceType":"module","externalDependencies":[]}