{"ast":null,"code":"const URL='https://abacus-2ntk.onrender.com/subject/updateSubject';const Token=localStorage.getItem('O_authDB');const updateSubject=(data,subjectID,setserverOperationError,setServerOperationLoading,setAllSystem)=>{setServerOperationLoading(true);fetch(\"\".concat(URL,\"/\").concat(subjectID),{method:'put',headers:{'Content-Type':'application/json','authrization':\"pracYas09\".concat(Token)},body:JSON.stringify(data)}).then(response=>response.json()).then(responseJson=>{if(responseJson.message==='success'){document.querySelector('.update-subject-popup').classList.replace('d-flex','d-none');setServerOperationLoading(false);setserverOperationError(null);setAllSystem(responseJson.allSystem);}else{setserverOperationError(responseJson.message);setServerOperationLoading(false);}}).catch(error=>{setserverOperationError(error.message);setServerOperationLoading(false);});};export default updateSubject;","map":null,"metadata":{},"sourceType":"module","externalDependencies":[]}