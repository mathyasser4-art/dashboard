{"ast":null,"code":"const URL='https://topsoroban.onrender.com/chapter/deleteChapter/';const Token=localStorage.getItem('O_authDB');const deleteChapter=(chapterID,setserverOperationError,setServerOperationLoading,navigate,questionTypeID,unitID,questionTypeName,subjectID)=>{setServerOperationLoading(true);fetch(\"\".concat(URL).concat(chapterID,\"/\").concat(unitID),{method:'delete',headers:{'Content-Type':'application/json','authrization':\"pracYas09\".concat(Token)}}).then(response=>response.json()).then(responseJson=>{if(responseJson.message==='success'){navigate(\"/unit/\".concat(questionTypeName,\"/\").concat(questionTypeID,\"/\").concat(subjectID));setServerOperationLoading(false);setserverOperationError(null);}else{setserverOperationError(responseJson.message);setServerOperationLoading(false);}}).catch(error=>{setserverOperationError(error.message);setServerOperationLoading(false);});};export default deleteChapter;","map":null,"metadata":{},"sourceType":"module","externalDependencies":[]}