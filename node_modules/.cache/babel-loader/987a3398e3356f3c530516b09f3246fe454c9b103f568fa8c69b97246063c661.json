{"ast":null,"code":"const URL='https://topsoroban.onrender.com/school/updateSchool';const Token=localStorage.getItem('O_authDB');const updateSchool=(data,schoolID,setserverOperationError,setServerOperationLoading,setAllSchools)=>{setServerOperationLoading(true);fetch(\"\".concat(URL,\"/\").concat(schoolID),{method:'put',headers:{'Content-Type':'application/json','authrization':\"pracYas09\".concat(Token)},body:JSON.stringify(data)}).then(response=>response.json()).then(responseJson=>{if(responseJson.message==='success'){setAllSchools(responseJson.allSchools);setServerOperationLoading(false);setserverOperationError(null);document.querySelector('.update-school-popup').classList.replace('d-flex','d-none');}else{setserverOperationError(responseJson.message);setServerOperationLoading(false);}}).catch(error=>{setserverOperationError(error.message);setServerOperationLoading(false);});};export default updateSchool;","map":null,"metadata":{},"sourceType":"module","externalDependencies":[]}