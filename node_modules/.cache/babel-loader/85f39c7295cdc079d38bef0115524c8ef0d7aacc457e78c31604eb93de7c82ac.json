{"ast":null,"code":"const URL='https://abacus-2ntk.onrender.com/unit/addUnit';const Token=localStorage.getItem('O_authDB');const addUnit=(data,setserverOperationError,setServerOperationLoading,setAllUnit)=>{setServerOperationLoading(true);fetch(\"\".concat(URL),{method:'post',headers:{'Content-Type':'application/json','authrization':\"pracYas09\".concat(Token)},body:JSON.stringify(data)}).then(response=>response.json()).then(responseJson=>{if(responseJson.message==='success'){document.querySelector('.add-unit-popup').classList.replace('d-flex','d-none');setServerOperationLoading(false);setserverOperationError(null);setAllUnit(responseJson.allUnit);}else{setserverOperationError(responseJson.message);setServerOperationLoading(false);}}).catch(error=>{setserverOperationError(error.message);setServerOperationLoading(false);});};export default addUnit;","map":null,"metadata":{},"sourceType":"module","externalDependencies":[]}