{"ast":null,"code":"const URL='https://practice-papers.onrender.com/school/getSchool';const Token=localStorage.getItem('O_authDB');const getAllSchool=(setAllSchools,setLoading)=>{setLoading(true);fetch(\"\".concat(URL),{method:'get',headers:{'Content-Type':'application/json','authrization':\"pracYas09\".concat(Token)}}).then(response=>response.json()).then(responseJson=>{if(responseJson.message==='success'){setAllSchools(responseJson.allSchools);setLoading(false);}else{setLoading(false);}}).catch(error=>{console.log(error.message);setLoading(false);});};export default getAllSchool;","map":null,"metadata":{},"sourceType":"module","externalDependencies":[]}