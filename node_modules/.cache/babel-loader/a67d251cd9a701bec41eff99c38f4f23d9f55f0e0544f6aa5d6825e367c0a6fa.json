{"ast":null,"code":"const URL='https://topsoroban.onrender.com/chapter/getChapterQuestion/';const getChapter=(chapterID,setChapterDetails,setLoading)=>{setLoading(true);fetch(\"\".concat(URL).concat(chapterID),{method:'get',headers:{'Content-Type':'application/json'}}).then(response=>response.json()).then(responseJson=>{if(responseJson.message==='success'){setChapterDetails(responseJson.chapter);setLoading(false);}else{setLoading(false);}}).catch(error=>{console.log(error.message);setLoading(false);});};export default getChapter;","map":null,"metadata":{},"sourceType":"module","externalDependencies":[]}