{"ast":null,"code":"const URL='https://topsoroban.onrender.com/system/updateSystem';const Token=localStorage.getItem('O_authDB');const updateSystem=(data,systemID,setserverOperationError,setServerOperationLoading,setAllSystem)=>{setServerOperationLoading(true);fetch(\"\".concat(URL,\"/\").concat(systemID),{method:'put',headers:{'Content-Type':'application/json','authrization':\"pracYas09\".concat(Token)},body:JSON.stringify(data)}).then(response=>response.json()).then(responseJson=>{if(responseJson.message==='success'){document.querySelector('.update-system-popup').classList.replace('d-flex','d-none');setServerOperationLoading(false);setserverOperationError(null);setAllSystem(responseJson.allSystem);}else{setserverOperationError(responseJson.message);setServerOperationLoading(false);}}).catch(error=>{setserverOperationError(error.message);setServerOperationLoading(false);});};export default updateSystem;","map":null,"metadata":{},"sourceType":"module","externalDependencies":[]}